{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "src/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "destination": "https://task-sync0418-master.vercel.app/"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
